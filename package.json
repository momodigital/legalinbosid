{
  "name": "legalinbosid",
  "version": "1.0.0",
  "description": "Landing page LegalInBossID - Jasa konsultasi legalitas dan perizinan bisnis profesional dengan desain modern tema gelap",
  "main": "index.html",
  "scripts": {
    "dev": "live-server --port=3000 --watch=index.html,assets",
    "start": "live-server --port=3000 --open=index.html --watch=index.html,assets",
    "build": "echo 'Static site, no build needed' && exit 0",
    "preview": "live-server --port=8080 --open=index.html",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "format": "prettier --write \"**/*.{html,js,json,md}\"",
    "lint": "htmlhint index.html",
    "validate": "html-validate index.html",
    "prepare": "husky install"
  },
  "keywords": [
    "legalinbosid",
    "legal-consultant",
    "perizinan-bisnis",
    "landing-page",
    "vercel",
    "dark-theme",
    "indonesia",
    "legalitas"
  ],
  "author": {
    "name": "LegalInBossID",
    "email": "info@legalinbosid.com",
    "url": "https://legalinbosid.vercel.app"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/momodigital/legalinbosid.git"
  },
  "bugs": {
    "url": "https://github.com/momodigital/legalinbosid/issues"
  },
  "homepage": "https://github.com/momodigital/legalinbosid#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "prettier": "^3.4.2",
    "htmlhint": "^1.1.4",
    "html-validate": "^8.24.0",
    "vercel": "^37.0.0",
    "husky": "^9.0.11"
  },
  "private": false,
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ]
}
